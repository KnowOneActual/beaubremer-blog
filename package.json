{
  "name": "beaubremer-blog-tailwind",
  "version": "1.0.0",
  "description": "",
  "main": "index.js",
  "scripts": {
    "watch:css": "npx @tailwindcss/cli -i ./src/css/tailwind.css -o ./_site/assets/css/style.css --watch",
    "watch:eleventy": "eleventy --serve",
    "start": "eleventy && npm-run-all --parallel watch:*",
    "build": "eleventy && npx @tailwindcss/cli -i ./src/css/tailwind.css -o ./_site/assets/css/style.css && npx pagefind --site _site",
    "format": "biome format --write . && npx prettier --write \"**/*.{njk,md}\"",
    "format:check": "biome check . && npx prettier --check \"**/*.{njk,md}\"",
    "lint": "biome lint . && npx markdownlint \"posts/**/*.md\" && npx secretlint \"**/*\"",
    "lint:fix": "biome check --write . && npx markdownlint --fix \"posts/**/*.md\"",
    "lefthook:install": "lefthook install",
    "clean": "rm -rf _site"
  },
  "keywords": [],
  "author": "",
  "license": "ISC",
  "overrides": {
    "brace-expansion": ">=5.0.5"
  },
  "devDependencies": {
    "@11ty/eleventy-img": "^6.0.4",
    "@biomejs/biome": "^2.4.16",
    "@secretlint/secretlint-rule-preset-recommend": "^13.0.2",
    "@tailwindcss/cli": "^4.3.1",
    "@tailwindcss/typography": "^0.5.19",
    "autoprefixer": "^10.5.0",
    "lefthook": "^2.1.9",
    "lite-youtube-embed": "^0.3.4",
    "luxon": "^3.7.2",
    "markdownlint-cli": "^0.48.0",
    "npm-run-all": "^4.1.5",
    "postcss": "^8.5.15",
    "prettier": "^3.8.3",
    "secretlint": "^13.0.2",
    "tailwindcss": "^4.2.2"
  },
  "dependencies": {
    "@11ty/eleventy": "^3.1.6",
    "@11ty/eleventy-plugin-rss": "^3.0.0",
    "@11ty/eleventy-plugin-syntaxhighlight": "^5.0.2",
    "glob": "^13.0.6",
    "http-server": "^14.1.1",
    "js-yaml": "^4.2.0"
  }
}
